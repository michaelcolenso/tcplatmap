PORT=8080
HOST=127.0.0.1

# Where the server reads sales data from (generated file).
SALES_DATA_PATH=./data/sales.json

# ArcGIS REST query endpoint for sales records (MapServer layer /query).
# Example:
# ARCGIS_SALES_URL="https://example.com/arcgis/rest/services/.../MapServer/2/query"
ARCGIS_SALES_URL=""

# Optional overrides for ArcGIS querying
ARCGIS_WHERE="1=1"
ARCGIS_PAGE_SIZE=2000
