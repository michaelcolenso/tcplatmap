PORT=8080
HOST=127.0.0.1

# Where the server reads sales data from (generated file).
SALES_DATA_PATH=./data/sales.json

# ArcGIS REST query endpoint for sales records (MapServer table /query).
# Default is the City of Traverse City sales table (see DATA-SOURCES.md);
# leave as-is unless you need to point at a different layer.
ARCGIS_SALES_URL="https://tcgis.traversecitymi.gov/arcgis/rest/services/Property/CityParcelViewer/MapServer/2/query"

# Optional overrides for ArcGIS querying
ARCGIS_WHERE="1=1"
ARCGIS_PAGE_SIZE=2000
