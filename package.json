{
  "name": "tcplats",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "data:fetch:sales": "node scripts/fetch-sales.js",
    "data:convert:legacy-sales": "node scripts/convert-legacy-sales.js",
    "test": "node --test test/*.test.js",
    "sync:sales": "node scripts/sync-sales.js",
    "sync:parcels": "node scripts/sync-parcels.js",
    "sync:auctions": "node scripts/sync-auctions.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply tcplatmap --remote"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelcolenso/tcplatmap.git"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "hono": "^4.12.31",
    "morgan": "^1.10.0",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "wrangler": "^4.25.0"
  }
}
